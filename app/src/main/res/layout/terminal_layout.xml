<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saber Terminal >_ Logic Editor"
        android:textColor="#4ADE80"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/logic_input"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:gravity="top"
        android:hint="// اكتب منطق التحكم هنا...\n// مثال: if fingers == 5 then start_engine"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        android:padding="10dp"
        android:inputType="textMultiLine" />

    <Button
        android:id="@+id/btn_save_logic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="حفظ وتشغيل المنطق"
        android:backgroundTint="#4ADE80"
        android:textColor="#1E1E1E"
        android:layout_marginTop="10dp"/>
</LinearLayout>
